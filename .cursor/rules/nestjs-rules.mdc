## ❌ Anti-Patterns (Evitar)

### 🚫 Nomenclatura Incorreta

```typescript
// ❌ Métodos em inglês
async findUserById(id: string) { }
async createUser(dto: CreateUserDto) { }
async updateUser(id: string, dto: UpdateUserDto) { }

// ❌ Entidades em português
class Usuario { }
class Empresa { }
class Posto { }

// ❌ Propriedades em português
interface User {
  identificador: string;
  nome: string;
  email: string;
}

// ❌ Endpoints em inglês
@Get() findAllUsers() { }
@Post() createUser() { }
@Put(':id') updateUser() { }
```

### 🚫 Padrões Inconsistentes

```typescript
// ❌ Mistura de padrões
async getUser(id: string) { }           // Deveria ser buscarUserPorId
async validateUser(id: string) { }      // Deveria ser validarSeUserExiste
async saveUser(dto: CreateUserDto) { }  // Deveria ser criarNovoUser
```

### 🚫 Arquitetura Incorreta

```typescript
// ❌ Lógica de negócio no controller
@Controller('users')
export class UsersController {
  @Post()
  async criarUser(@Body() dto: CreateUserDto) {
    // ❌ Validação no controller
    if (!dto.email) {
      throw new BadRequestException('Email é obrigatório');
    }

    // ❌ Acesso direto ao banco
    const user = await this.prisma.user.create({ data: dto });
    return user;
  }
}

// ❌ Validação misturada com lógica de negócio
@Injectable()
export class UserService {
  async criarUser(dto: CreateUserDto) {
    // ❌ Validação, criação e persistência no mesmo lugar
    if (!dto.email) throw new Error('Email obrigatório');
    const hashedPassword = await bcrypt.hash(dto.password, 10);
    return this.prisma.user.create({
      data: { ...dto, password: hashedPassword },
    });
  }
}
```

