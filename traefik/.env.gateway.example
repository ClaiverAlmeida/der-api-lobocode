# Traefik (HTTP-01) — só para traefik/docker-compose.vps-gateway.yml
# Copie para traefik/.env.gateway e preencha. Suba uma vez por VPS (infra compartilhada).
# Não misture com o .env da aplicação no repositório do app.

VPS_GATEWAY_PROJECT_NAME=vps-traefik-gateway
VPS_GATEWAY_COMPOSE_FILE=traefik/docker-compose.vps-gateway.yml

TRAEFIK_NETWORK=reverse-proxy
TRAEFIK_CERT_RESOLVER=letsencrypt
# v3.6+ — Docker Engine 29+ exige API ≥1.40; v3.2 falha com "client version 1.24 is too old"
TRAEFIK_IMAGE_TAG=v3.6
TRAEFIK_PUBLISH_HTTP=80
TRAEFIK_PUBLISH_HTTPS=443
TRAEFIK_LOG_LEVEL=INFO
TRAEFIK_LETSENCRYPT_VOLUME_NAME=traefik-letsencrypt

# Obrigatório para Let's Encrypt. Sem e-mail o Traefik fica com certificado interno (browser: ERR_CERT_*).
# O gateway usa TLS-ALPN-01 (porta 443). Se trocou de HTTP-01 e o cert ficou preso, apague o volume do acme.json e suba o gateway de novo.
LETSENCRYPT_EMAIL=
