# Traefik (config em arquivo) — só para traefik/docker-compose.traefik-file-provider.yml
# Copie para traefik/.env.traefik-file-provider. Alternativa ao vps-gateway; não use os dois na mesma porta.

TRAEFIK_FILE_PROVIDER_PROJECT_NAME=vps-traefik-file-provider
TRAEFIK_FILE_PROVIDER_COMPOSE_FILE=traefik/docker-compose.traefik-file-provider.yml

TRAEFIK_NETWORK=reverse-proxy
TRAEFIK_IMAGE_TAG=v3.6
TRAEFIK_PUBLISH_HTTP=80
TRAEFIK_PUBLISH_HTTPS=443
TRAEFIK_FILE_PROVIDER_VOLUME_NAME=traefik-file-provider-data

LETSENCRYPT_EMAIL=
