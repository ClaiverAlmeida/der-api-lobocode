# Gerado a partir de traefik/.env.gateway.example — Traefik compartilhado da VPS (não commitar).

VPS_GATEWAY_PROJECT_NAME=vps-traefik-gateway
VPS_GATEWAY_COMPOSE_FILE=traefik/docker-compose.vps-gateway.yml

TRAEFIK_NETWORK=reverse-proxy
TRAEFIK_CERT_RESOLVER=letsencrypt
TRAEFIK_IMAGE_TAG=v3.6
TRAEFIK_PUBLISH_HTTP=80
TRAEFIK_PUBLISH_HTTPS=443
TRAEFIK_LOG_LEVEL=INFO
TRAEFIK_LETSENCRYPT_VOLUME_NAME=traefik-letsencrypt

LETSENCRYPT_EMAIL=devops@lobocode.com.br
